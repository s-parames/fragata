# Daily ingest — environment template
# Copy this file to state/daily_ingest.env and fill in real values.
# state/daily_ingest.env is gitignored and must never be committed.

# ── RT / MySQL database ────────────────────────────────────────────────────────
export DAILY_DB_HOST="<DB_HOST_IP>"
export DAILY_DB_PORT="3306"
export DAILY_DB_USER="<DB_USER>"
export DAILY_DB_PASSWORD="<DB_PASSWORD>"
export DAILY_DB_NAME="<DB_NAME>"

# ── Supercomputer (FT3) connection from the VM ─────────────────────────────────
# The VM triggers GPU compute jobs on FT3 via SSH + the `compute` wrapper.
export DAILY_INGEST_REQUEST_SUPERCOMPUTE="1"
export DAILY_INGEST_COMPUTE_BIN="scripts/compute_via_ft3.sh"
export DAILY_INGEST_COMPUTE_CPUS="32"
export DAILY_INGEST_COMPUTE_MEM="32G"
export DAILY_INGEST_COMPUTE_GPU="1"

export DAILY_INGEST_REMOTE_USER="<YOUR_FT3_USERNAME>"
export DAILY_INGEST_REMOTE_HOST="ft3.cesga.es"
# Path to the SSH private key on the VM that is authorised on the FT3 account above.
export DAILY_INGEST_REMOTE_SSH_KEY="/home/<VM_USER>/.ssh/<KEY_NAME>"
# Absolute path to the rag/ directory on FT3.
export DAILY_INGEST_REMOTE_WORKDIR="/mnt/netapp1/Store_CESGA/home/cesga/<YOUR_FT3_USERNAME>/rag"
export DAILY_INGEST_REMOTE_COMPUTE_BIN="compute"
export DAILY_INGEST_REMOTE_STRICT_HOST_KEY_CHECKING="accept-new"

# ── Sync-back and engine reload ────────────────────────────────────────────────
# After compute finishes on FT3, rsync the new FAISS index back to the VM and
# trigger a live engine reload via the local API.
export RAG_ENGINE_RELOAD_URL=""
export RAG_ENGINE_RELOAD_REQUIRED="0"
export DAILY_INGEST_SYNC_BACK_ENABLE="1"
export DAILY_INGEST_SYNC_BACK_RELOAD_URL="http://127.0.0.1:8010/admin/engine/reload"
export DAILY_INGEST_SYNC_BACK_RELOAD_TIMEOUT_SEC="900"
export DAILY_INGEST_SYNC_BACK_RELOAD_REQUIRED="1"
