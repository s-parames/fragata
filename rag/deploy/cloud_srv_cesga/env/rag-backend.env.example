# Backend runtime settings
RAG_SKIP_WARMUP=0
RAG_MAX_PDF_UPLOAD_BYTES=20971520

# CORS settings for split frontend/backend deployment
# Put your frontend URL here (comma-separated values supported).
RAG_CORS_ALLOW_ORIGINS=https://rag-front.example.cesga.es
RAG_CORS_ALLOW_METHODS=GET,POST,OPTIONS
RAG_CORS_ALLOW_HEADERS=*
RAG_CORS_ALLOW_CREDENTIALS=0
RAG_CORS_MAX_AGE=600

# Optional: VM -> supercomputer HPC offload for ingestion/index stages
# Set RAG_HPC_ENABLED=1 to activate remote execution in configured source types.
RAG_HPC_ENABLED=0
RAG_HPC_SOURCE_TYPES=web,pdf,repo_docs,rt_weekly
RAG_HPC_CORES=32
RAG_HPC_MEM=32G
RAG_HPC_GPU=1
RAG_HPC_TIMEOUT_SEC=0
RAG_HPC_PYTHON_BIN=/mnt/netapp1/Store_CESGA/home/cesga/tec_app2/rag/RAG/bin/python
RAG_HPC_RELEASE_POLICY=auto
RAG_HPC_REMOTE_HOST=ft3.cesga.es
RAG_HPC_REMOTE_USER=tec_app2
RAG_HPC_SSH_KEY_PATH=/home/cesgaxuser/.ssh/rag_hpc
RAG_HPC_REMOTE_WORKDIR=/mnt/netapp1/Store_CESGA/home/cesga/tec_app2/rag
# Optional: custom wrapper using placeholders {compute} and {payload}
# RAG_HPC_SUBMIT_TEMPLATE={compute} -- bash -lc {payload}
# Optional: custom cancel template (must include {allocation_id})
# RAG_HPC_CANCEL_TEMPLATE=scancel {allocation_id}
# Optional: ssh binary and host-key policy
# RAG_HPC_SSH_BINARY=ssh
# RAG_HPC_STRICT_HOST_KEY_CHECKING=accept-new

# Optional: regex-based origin allow-list.
# RAG_CORS_ALLOW_ORIGIN_REGEX=https://.*\.example\.cesga\.es
